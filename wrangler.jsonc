{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "toolhub",
  "compatibility_date": "2026-03-27",
  "main": ".cloudflare/worker.js",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application"
  },
  "observability": {
    "enabled": true
  }
}
